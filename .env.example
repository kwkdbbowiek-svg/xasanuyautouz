# Copy this file to .env and fill in your values
# Railway automatically injects these as environment variables

BOT_TOKEN=7123456789:AAHxxx_your_bot_token_here

# Railway PostgreSQL plugin injects DATABASE_URL automatically.
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/uysavdouz

# Comma-separated Telegram user IDs of super admins (no spaces)
SUPER_ADMIN_IDS=123456789,987654321

# Optional tuning (defaults shown)
THROTTLE_RATE=1.2
THROTTLE_BAN_DURATION=900
THROTTLE_MAX_VIOLATIONS=5
SCHEDULER_INTERVAL_HOURS=1
LOG_FILE=bot_errors.log
